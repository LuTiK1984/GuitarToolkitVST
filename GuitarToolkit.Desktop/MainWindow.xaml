<Window x:Class="GuitarToolkit.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GuitarToolkit" Height="650" Width="950"
        Background="#1A1525" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель выбора устройства -->
        <Border Grid.Row="0" Background="#251D38" Padding="12 8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Устройство ввода:" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="0 0 10 0" FontSize="13"/>
                <ComboBox x:Name="DeviceBox" Width="300" Height="30"
                          Background="#4A3860" Foreground="#CDD6F4"
                          FontSize="13" BorderThickness="0"
                          SelectionChanged="DeviceBox_SelectionChanged"/>
                <TextBlock x:Name="StatusLabel" Text="" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="16 0 0 0" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое — ToolkitHostView -->
        <ContentControl Grid.Row="1" x:Name="ContentArea"/>
    </Grid>
</Window>

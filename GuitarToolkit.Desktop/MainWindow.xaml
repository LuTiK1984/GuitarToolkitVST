<Window x:Class="GuitarToolkit.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="GuitarToolkit v1.5.0"
        Icon="Assets/GuitarToolkit.ico"
        Width="1050" Height="720"
        MinWidth="1050" MinHeight="720"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1A1525"/>
        <SolidColorBrush x:Key="TitleBarBrush" Color="#2D2240"/>
        <SolidColorBrush x:Key="TitleBorderBrush" Color="#5B4676"/>
        <SolidColorBrush x:Key="TitleInnerGlowBrush" Color="#18CBA6F7"/>
        <SolidColorBrush x:Key="TitleButtonBrush" Color="#231C31"/>
        <SolidColorBrush x:Key="TitleTextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TitleMutedBrush" Color="#9B8BB8"/>
        <SolidColorBrush x:Key="TitleHoverBrush" Color="#64CBA6F7"/>
        <SolidColorBrush x:Key="TitleCloseHoverBrush" Color="#D8F38BA8"/>
        <SolidColorBrush x:Key="TitleDarkBrush" Color="#1A1525"/>

        <Style x:Key="WindowButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource TitleButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TitleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TitleHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TitleHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TitleCloseHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TitleCloseHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar"
                Grid.Row="0"
                Margin="5 4 5 5"
                Background="{DynamicResource TitleBarBrush}"
                BorderBrush="{DynamicResource TitleBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="3"
                        Height="13"
                        Margin="1 1 1 0"
                        VerticalAlignment="Top"
                        Background="{DynamicResource TitleInnerGlowBrush}"
                        CornerRadius="7 7 3 3"
                        IsHitTestVisible="False"/>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10 0 0 0">
                    <Image Source="Assets/GuitarToolkit.ico"
                           Width="16"
                           Height="16"
                           Margin="0 0 6 0"/>
                    <TextBlock Text="GuitarToolkit v1.5.0"
                               Foreground="{DynamicResource TitleTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="0 0 6 0">
                    <Button Content="&#x2014;"
                            Style="{StaticResource WindowButton}"
                            Margin="0 0 5 0"
                            Click="Minimize_Click"/>
                    <Button x:Name="MaximizeButton"
                            Content="&#x25A1;"
                            Style="{StaticResource WindowButton}"
                            Margin="0 0 5 0"
                            Click="Maximize_Click"/>
                    <Button Content="&#x00D7;"
                            Style="{StaticResource CloseButton}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        x:Name="ContentArea"/>
    </Grid>
</Window>

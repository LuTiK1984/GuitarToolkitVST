<UserControl x:Class="GuitarToolkit.Plugin.UI.PluginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GuitarToolkit.Plugin.UI"
             Background="#1E1E2E">

    <UserControl.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14 10"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
    </UserControl.Resources>

    <TabControl Background="#1E1E2E" BorderThickness="0" TabStripPlacement="Left">

        <TabItem Header="🎸 Тюнер">
            <local:TunerView x:Name="TunerTab"/>
        </TabItem>

        <TabItem Header="🥁 Метроном">
            <local:MetronomeView x:Name="MetronomeTab"/>
        </TabItem>

        <TabItem Header="🎵 Аккорды">
            <Grid>
                <TextBlock Text="Справочник аккордов — в разработке"
                           Foreground="#6C7086" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </TabItem>

        <TabItem Header="🎼 Гаммы">
            <Grid>
                <TextBlock Text="Визуализатор грифа — в разработке"
                           Foreground="#6C7086" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>

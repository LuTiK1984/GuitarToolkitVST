<UserControl x:Class="GuitarToolkit.UI.CircleOfFifthsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Круг -->
        <Canvas x:Name="CircleCanvas" Grid.Column="0"
                Background="Transparent"
                SizeChanged="Canvas_SizeChanged"/>

        <!-- Информация о выбранной тональности -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16 0 0 0">

            <TextBlock x:Name="KeyNameLabel" Text="C мажор"
                       FontSize="32" FontWeight="Bold" Foreground="#CDD6F4"
                       Margin="0 0 0 4"/>
            <TextBlock x:Name="MinorLabel" Text="Параллельный: Am"
                       FontSize="16" Foreground="#7C6F96"
                       Margin="0 0 0 4"/>
            <TextBlock x:Name="SignatureLabel" Text="Без знаков"
                       FontSize="16" Foreground="#CBA6F7"
                       Margin="0 0 0 24"/>

            <TextBlock Text="Диатонические аккорды:" FontSize="14"
                       Foreground="#7C6F96" Margin="0 0 0 10"/>
            <ItemsControl x:Name="ChordsDisplay">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <TextBlock Text="Родственные тональности:" FontSize="14"
                       Foreground="#7C6F96" Margin="0 24 0 10"/>
            <TextBlock x:Name="RelatedLabel" Text=""
                       FontSize="14" Foreground="#CDD6F4"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="GuitarToolkit.UI.InspirationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#241B33"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#352847"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#4B3A64"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#5B4676"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="StartBrush" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#F38BA8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9B8BB8"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#1A1525"/>

        <Style x:Key="Panel" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionPanel" TargetType="{x:Type Border}" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="{DynamicResource DarkBrush}"/>
            <Setter Property="Padding" Value="10 8"/>
        </Style>

        <Style x:Key="GroupLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InspirationButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource InspirationButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
        </Style>

        <Style x:Key="PlayButton" TargetType="{x:Type Button}" BasedOn="{StaticResource InspirationButton}">
            <Setter Property="Background" Value="{DynamicResource StartBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StartBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource InspirationButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
        </Style>

        <Style x:Key="InspirationTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8" MinWidth="880">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Panel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="300"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="2*" MinWidth="310"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Тоника" Style="{StaticResource GroupLabel}"/>
                    <ComboBox x:Name="RootBox" Grid.Row="1" Grid.Column="0"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Лад" Style="{StaticResource GroupLabel}"/>
                    <ComboBox x:Name="ModeBox" Grid.Row="1" Grid.Column="2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Тактов" Style="{StaticResource GroupLabel}"/>
                    <ComboBox x:Name="BarsBox" Grid.Row="4" Grid.Column="0"/>

                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Seed-ступени" Style="{StaticResource GroupLabel}"/>
                    <TextBox x:Name="SeedTokensBox"
                             Grid.Row="4"
                             Grid.Column="2"
                             Style="{StaticResource InspirationTextBox}"
                             ToolTip="Например: i, VI"/>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Стиль" Style="{StaticResource GroupLabel}"/>
                    <ComboBox x:Name="StyleBox" Grid.Row="1" Grid.Column="0"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Настроение" Style="{StaticResource GroupLabel}"/>
                    <ComboBox x:Name="MoodBox" Grid.Row="1" Grid.Column="2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Вариативность" Style="{StaticResource GroupLabel}"/>
                    <Slider x:Name="TemperatureSlider"
                            Grid.Row="4"
                            Grid.Column="0"
                            Minimum="0.2"
                            Maximum="1.5"
                            Value="0.85"
                            ValueChanged="Temperature_Changed"/>

                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="TemperatureLabel"
                                   Text="0.85"
                                   Width="44"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Выборка"
                                   Style="{StaticResource GroupLabel}"
                                   Margin="8 0 6 0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="TopKBox" Width="64"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="4"
                            VerticalAlignment="Bottom">
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="62"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Темп" Style="{StaticResource GroupLabel}"/>
                        <TextBlock x:Name="TempoLabel"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Text="96 BPM"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                        <Slider x:Name="TempoSlider"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Minimum="50"
                                Maximum="220"
                                Value="96"
                                TickFrequency="1"
                                ValueChanged="Tempo_Changed"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Громкость" Style="{StaticResource GroupLabel}"/>
                        <TextBlock x:Name="VolumeLabel"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Text="75%"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                        <Slider x:Name="VolumeSlider"
                                Grid.Row="4"
                                Grid.ColumnSpan="2"
                                Minimum="0"
                                Maximum="100"
                                Value="75"
                                TickFrequency="1"
                                ValueChanged="Volume_Changed"/>
                    </Grid>
                    <CheckBox x:Name="LoopCheck"
                              Content="Цикл"
                              Margin="0 0 0 8"
                              VerticalAlignment="Center"/>
                    <Button Content="Сгенерировать"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0 0 0 6"
                            Click="Generate_Click"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="▶ Играть"
                                Style="{StaticResource PlayButton}"
                                Click="Play_Click"/>
                        <Button x:Name="StopButton"
                                Grid.Column="2"
                                Content="Стоп"
                                Style="{StaticResource DangerButton}"
                                Visibility="Collapsed"
                                Click="Stop_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="42*"/>
            </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Сгенерированная прогрессия"
                               Style="{StaticResource GroupLabel}"/>
                    <Border Grid.Row="2" Style="{StaticResource SectionPanel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ProgressionItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Статус модели" Style="{StaticResource GroupLabel}"/>
                        <TextBlock x:Name="ModelStatusText"
                                   Style="{StaticResource MutedText}"
                                   Text="Модель будет загружена при генерации."/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Как использовать идею" Style="{StaticResource GroupLabel}"/>
                        <TextBlock x:Name="ScaleText"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0 0 0 8"/>
                        <TextBlock x:Name="ExplanationText"
                                   Style="{StaticResource MutedText}"
                                   Margin="0 0 0 10"/>
                        <TextBlock x:Name="GuitarHintText"
                                   Style="{StaticResource MutedText}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

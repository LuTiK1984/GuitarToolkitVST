<UserControl x:Class="GuitarToolkit.UI.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="820">
            <TextBlock Text="GuitarToolkit"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#CDD6F4"
                       Margin="0 0 0 4"/>

            <TextBlock x:Name="VersionText"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#CBA6F7"
                       Margin="0 0 0 18"/>

            <TextBlock Text="Личный идейный проект для гитарной практики, набросков и музыкальных экспериментов. Desktop-приложение и VST3-плагин используют общий интерфейс, общее ядро и общий набор инструментов."
                       TextWrapping="Wrap"
                       FontSize="15"
                       LineHeight="22"
                       Foreground="#CDD6F4"
                       Margin="0 0 0 22"/>

            <Border Background="#241B33"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="Ссылки и диагностика"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 12"/>

                    <WrapPanel>
                        <Button Content="GitHub"
                                Width="120"
                                Height="34"
                                Margin="0 0 10 10"
                                Click="GitHub_Click"/>
                        <Button Content="Логи"
                                Width="120"
                                Height="34"
                                Margin="0 0 10 10"
                                Click="Logs_Click"/>
                    </WrapPanel>

                    <TextBlock Text="Папка логов:"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#A894C8"
                               Margin="0 2 0 3"/>
                    <TextBlock x:Name="LogPathText"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#7C6F96"/>
                </StackPanel>
            </Border>

            <Border Background="#241B33"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="Что внутри"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 12"/>

                    <TextBlock Text="Тюнер, метроном, аккорды, гаммы, интервалы, прогрессии и круг квинт."
                               TextWrapping="Wrap"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 6"/>
                    <TextBlock Text="Открытие Guitar Pro и MusicXML, выбор дорожек, прослушивание табулатур, solo/mute и слежение за курсором."
                               TextWrapping="Wrap"
                               Foreground="#CDD6F4"/>
                </StackPanel>
            </Border>

            <Border Background="#241B33"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="Основные библиотеки"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 12"/>

                    <TextBlock Text="AudioPlugSharp / AudioPlugSharpWPF - VST3 bridge"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 6"/>
                    <TextBlock Text="NAudio - desktop audio input/output"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 6"/>
                    <TextBlock Text="alphaTab / AlphaSkia - Guitar Pro and MusicXML rendering/playback"
                               Foreground="#CDD6F4"
                               Margin="0 0 0 6"/>
                    <TextBlock Text="xUnit - automated tests"
                               Foreground="#CDD6F4"/>
                </StackPanel>
            </Border>

            <TextBlock Text="VST is a trademark of Steinberg Media Technologies GmbH. Third-party libraries belong to their respective authors."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#7C6F96"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

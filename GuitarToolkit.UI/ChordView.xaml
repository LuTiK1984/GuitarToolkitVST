<UserControl x:Class="GuitarToolkit.UI.ChordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#241B33"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#352847"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#4B3A64"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#5B4676"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#F38BA8"/>
        <SolidColorBrush x:Key="FavBrush" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9B8BB8"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#1A1525"/>

        <Style x:Key="Panel" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionPanel" TargetType="{x:Type Border}" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="{DynamicResource DarkBrush}"/>
            <Setter Property="Padding" Value="10 8"/>
        </Style>

        <Style x:Key="GroupLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChordButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Padding" Value="8 0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ChordButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="34*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="66*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Аккорд"
                                   Style="{StaticResource GroupLabel}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="ChordNameLabel"
                                   Text="C"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="FavButton"
                            Grid.Column="0"
                            Content="☆"
                            Style="{StaticResource ChordButton}"
                            Width="34"
                            Height="30"
                            FontSize="18"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="Fav_Click"/>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource SectionPanel}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TypeNameLabel"
                                   Text="Мажор"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="FormulaLabel"
                                   Text="1 - 3 - 5"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0 4 0 0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="NotesLabel"
                                   Text="C  E  G"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="0 4 0 0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Style="{StaticResource SectionPanel}">
                    <Canvas x:Name="DiagramCanvas"
                            Width="220"
                            Height="250"
                            Background="Transparent"
                            HorizontalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="‹"
                            Grid.Column="0"
                            Style="{StaticResource ChordButton}"
                            Width="34"
                            Click="PrevPosition_Click"/>
                    <TextBlock x:Name="PositionLabel"
                               Grid.Column="1"
                               Text="1 / 1"
                               Style="{StaticResource MutedText}"
                               TextAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Button Content="›"
                            Grid.Column="2"
                            Style="{StaticResource ChordButton}"
                            Width="34"
                            Click="NextPosition_Click"/>
                </Grid>

                <StackPanel Grid.Row="8">
                    <TextBlock x:Name="FretInfoLabel"
                               Style="{StaticResource MutedText}"
                               TextAlignment="Center"
                               Margin="0 0 0 8"/>
                    <Button x:Name="PlayButton"
                            Content="▶ Воспроизвести"
                            Style="{StaticResource PrimaryButton}"
                            Height="32"
                            Click="PlayButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="Фильтр"
                               Style="{StaticResource GroupLabel}"/>
                    <WrapPanel>
                        <Button x:Name="FilterAllBtn"
                                Content="Все"
                                Style="{StaticResource ChordButton}"
                                Width="64"
                                Margin="0 0 6 6"
                                Click="FilterAll_Click"/>
                        <Button x:Name="FilterEasyBtn"
                                Content="Простые"
                                Style="{StaticResource ChordButton}"
                                Width="86"
                                Margin="0 0 6 6"
                                Click="FilterEasy_Click"/>
                        <Button x:Name="FilterBarreBtn"
                                Content="Баррэ"
                                Style="{StaticResource ChordButton}"
                                Width="72"
                                Margin="0 0 6 6"
                                Click="FilterBarre_Click"/>
                        <Button x:Name="FilterFavBtn"
                                Content="★ Избранное"
                                Style="{StaticResource ChordButton}"
                                Width="116"
                                Margin="0 0 6 6"
                                Click="FilterFav_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="60*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Тоника"
                                   Style="{StaticResource GroupLabel}"/>
                        <ItemsControl x:Name="RootSelector">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Тип аккорда"
                                   Style="{StaticResource GroupLabel}"/>
                        <ItemsControl x:Name="TypeSelector">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Аппликатура"
                               Style="{StaticResource GroupLabel}"/>
                    <Border Grid.Row="2"
                            Style="{StaticResource SectionPanel}">
                        <TextBlock x:Name="InfoLabel"
                                   Style="{StaticResource MutedText}"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

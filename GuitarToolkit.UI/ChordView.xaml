<UserControl x:Class="GuitarToolkit.UI.ChordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ — Диаграмма -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top"
                    HorizontalAlignment="Center" Margin="16 0 32 0">

            <!-- Имя аккорда + избранное -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 4">
                <TextBlock x:Name="ChordNameLabel" Text="C"
                           FontSize="44" FontWeight="Bold" Foreground="#CDD6F4"/>
                <Button x:Name="FavButton" Content="☆" FontSize="28"
                        Width="40" Height="40"
                        Background="Transparent" Foreground="#7C6F96"
                        BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Margin="4 0 0 0"
                        Click="Fav_Click"/>
            </StackPanel>

            <!-- Полное название типа -->
            <TextBlock x:Name="TypeNameLabel" Text="Мажор"
                       FontSize="13" Foreground="#7C6F96"
                       HorizontalAlignment="Center" Margin="0 0 0 2"/>

            <!-- Формула -->
            <TextBlock x:Name="FormulaLabel" Text="1 – 3 – 5"
                       FontSize="14" Foreground="#CBA6F7" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0 0 0 2"/>

            <!-- Ноты -->
            <TextBlock x:Name="NotesLabel" Text="C  E  G"
                       FontSize="14" Foreground="#CDD6F4"
                       HorizontalAlignment="Center" Margin="0 0 0 8"/>

            <!-- Диаграмма -->
            <Canvas x:Name="DiagramCanvas" Width="200" Height="240"
                    Background="Transparent" HorizontalAlignment="Center"/>

            <!-- Навигация позиций -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 8 0 0">
                <Button Content="◀" Width="36" Height="32" FontSize="16"
                        Background="#4A3860" Foreground="#CDD6F4" BorderThickness="0"
                        Cursor="Hand" Click="PrevPosition_Click"/>
                <TextBlock x:Name="PositionLabel" Text="1 / 1"
                           FontSize="13" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="12 0"
                           MinWidth="80" TextAlignment="Center"/>
                <Button Content="▶" Width="36" Height="32" FontSize="16"
                        Background="#4A3860" Foreground="#CDD6F4" BorderThickness="0"
                        Cursor="Hand" Click="NextPosition_Click"/>
            </StackPanel>

            <!-- Позиция лад -->
            <TextBlock x:Name="FretInfoLabel" Text="Открытая позиция"
                       FontSize="12" Foreground="#7C6F96"
                       HorizontalAlignment="Center" Margin="0 4 0 8"/>

            <!-- Воспроизведение -->
            <Button x:Name="PlayButton" Content="♪  Воспроизвести"
                    Height="38" FontSize="14" FontWeight="Bold"
                    Foreground="#1A1525" Background="#CBA6F7"
                    BorderThickness="0" Cursor="Hand"
                    Width="200" Click="PlayButton_Click"/>
        </StackPanel>

        <!-- ПРАВАЯ ЧАСТЬ — Выбор -->
        <StackPanel Grid.Column="1" VerticalAlignment="Top">

            <!-- Фильтры -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                <Button x:Name="FilterAllBtn" Content="Все" Height="28"
                        FontSize="12" Margin="0 0 6 0" Padding="12 0"
                        Background="#CBA6F7" Foreground="#1A1525"
                        BorderThickness="0" Cursor="Hand" Click="FilterAll_Click"/>
                <Button x:Name="FilterEasyBtn" Content="Простые" Height="28"
                        FontSize="12" Margin="0 0 6 0" Padding="12 0"
                        Background="#4A3860" Foreground="#CDD6F4"
                        BorderThickness="0" Cursor="Hand" Click="FilterEasy_Click"/>
                <Button x:Name="FilterBarreBtn" Content="Баррэ" Height="28"
                        FontSize="12" Margin="0 0 6 0" Padding="12 0"
                        Background="#4A3860" Foreground="#CDD6F4"
                        BorderThickness="0" Cursor="Hand" Click="FilterBarre_Click"/>
                <Button x:Name="FilterFavBtn" Content="⭐ Избранное" Height="28"
                        FontSize="12" Margin="0 0 6 0" Padding="12 0"
                        Background="#4A3860" Foreground="#CDD6F4"
                        BorderThickness="0" Cursor="Hand" Click="FilterFav_Click"/>
            </StackPanel>

            <!-- Тоника -->
            <TextBlock Text="Тоника" FontSize="14" Foreground="#7C6F96" Margin="0 0 0 8"/>
            <ItemsControl x:Name="RootSelector">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Тип -->
            <TextBlock Text="Тип аккорда" FontSize="14" Foreground="#7C6F96" Margin="0 20 0 8"/>
            <ItemsControl x:Name="TypeSelector">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Аппликатура текстом -->
            <TextBlock x:Name="InfoLabel" Text="" FontSize="13"
                       Foreground="#7C6F96" Margin="0 20 0 0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>

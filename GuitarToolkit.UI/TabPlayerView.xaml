<UserControl x:Class="GuitarToolkit.UI.TabPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:AlphaTab.Wpf;assembly=AlphaTab.Windows"
             Background="#1A1525">

    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#241B33"/>
            <Setter Property="BorderBrush" Value="#352847"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9B8BB8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 5"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9B8BB8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 7 8"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9B8BB8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TabActionButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="Background" Value="#4B3A64"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource TabActionButton}">
            <Setter Property="Background" Value="#CBA6F7"/>
            <Setter Property="Foreground" Value="#1A1525"/>
        </Style>

        <Style x:Key="TabModeToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="#4B3A64"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#4B3A64"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#5B4676"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5B4676"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#CBA6F7"/>
                                <Setter Property="Foreground" Value="#1A1525"/>
                                <Setter Property="BorderBrush" Value="#CBA6F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    Background="#1A1525"
                                    BorderBrush="#4B3A64"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0 0 6 0">
                                <TextBlock x:Name="Mark"
                                           Text="✓"
                                           Foreground="#1A1525"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#A6E3A1"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#A6E3A1"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#CBA6F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4"
                                    Background="#4B3A64"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Background="#CBA6F7"
                                                  BorderThickness="0"
                                                  Height="4"
                                                  Opacity="0.95"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Height="4"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="22" Background="#CDD6F4"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Margin="0 0 0 12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 18 0">
                        <TextBlock Text="Файлы"
                                   Style="{StaticResource GroupLabel}"/>
                        <WrapPanel>
                            <Button Content="Открыть"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Width="110"
                                    Margin="0 0 8 8"
                                    Click="OpenFile_Click"/>

                            <Button Content="Папка"
                                    Style="{StaticResource TabActionButton}"
                                    Width="82"
                                    Margin="0 0 8 8"
                                    ToolTip="Выбрать папку библиотеки табов"
                                    Click="ChooseLibraryFolder_Click"/>

                            <Button Content="⟳"
                                    Style="{StaticResource TabActionButton}"
                                    Width="42"
                                    Margin="0 0 16 8"
                                    ToolTip="Обновить библиотеку табов"
                                    Click="RefreshLibrary_Click"/>

                            <TextBlock Text="Источник"
                                       Style="{StaticResource FieldLabel}"/>

                            <ComboBox x:Name="FileSourceCombo"
                                      Width="132" Height="34"
                                      Margin="0 0 8 8"
                                      SelectedIndex="0"
                                      SelectionChanged="FileSourceCombo_SelectionChanged">
                                <ComboBoxItem Content="Библиотека"/>
                                <ComboBoxItem Content="Недавние"/>
                                <ComboBoxItem Content="Избранное"/>
                            </ComboBox>

                            <TextBlock Text="Файл"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="8 0 7 8"/>

                            <ComboBox x:Name="FileChoiceCombo"
                                      Width="330" Height="34"
                                      Margin="0 0 8 8"
                                      ToolTip="Выбранный источник файлов"
                                      ItemsSource="{Binding CurrentTabFiles}"
                                      SelectionChanged="FileChoiceCombo_SelectionChanged"/>

                            <ToggleButton x:Name="FavoriteToggle"
                                          Content="☆"
                                          Style="{StaticResource TabModeToggleStyle}"
                                          Width="42" Height="34"
                                          Margin="0 0 0 8"
                                          ToolTip="Добавить текущий файл в избранное"
                                          Checked="FavoriteToggle_Changed"
                                          Unchecked="FavoriteToggle_Changed"/>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" MinWidth="420">
                        <TextBlock Text="Воспроизведение"
                                   Style="{StaticResource GroupLabel}"/>
                        <WrapPanel>
                            <ToggleButton x:Name="PlayPauseToggle"
                                          Content="▶ Играть"
                                          Style="{StaticResource TabModeToggleStyle}"
                                          Width="112" Height="34"
                                          Margin="0 0 8 8"
                                          ToolTip="Играть / пауза"
                                          Checked="PlayPauseToggle_Changed"
                                          Unchecked="PlayPauseToggle_Changed"/>

                            <Button Content="Стоп"
                                    Style="{StaticResource TabActionButton}"
                                    Width="76"
                                    Margin="0 0 14 8"
                                    ToolTip="Стоп"
                                    Click="Stop_Click"/>

                            <TextBlock Text="Громкость"
                                       Style="{StaticResource FieldLabel}"/>

                            <Slider x:Name="VolumeSlider"
                                    Width="130"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="35"
                                    TickFrequency="5"
                                    VerticalAlignment="Center"
                                    Margin="0 0 6 8"
                                    ValueChanged="VolumeSlider_ValueChanged"/>

                            <TextBlock x:Name="VolumeLabel"
                                       Text="35%"
                                       Width="42"
                                       VerticalAlignment="Center"
                                       Foreground="#CDD6F4"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0 0 0 8"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0 4 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 18 0">
                        <TextBlock Text="Дорожка"
                                   Style="{StaticResource GroupLabel}"/>
                        <WrapPanel>
                            <ComboBox x:Name="TrackCombo"
                                      Width="250" Height="34"
                                      Margin="0 0 8 8"
                                      SelectionChanged="TrackCombo_SelectionChanged"/>

                            <ToggleButton x:Name="SoloToggle"
                                          Content="Соло"
                                          Style="{StaticResource TabModeToggleStyle}"
                                          Width="70" Height="34"
                                          Margin="0 0 8 8"
                                          ToolTip="Играть только выбранную дорожку"
                                          Checked="SoloToggle_Changed"
                                          Unchecked="SoloToggle_Changed"/>

                            <ToggleButton x:Name="MuteToggle"
                                          Content="Не играть"
                                          Style="{StaticResource TabModeToggleStyle}"
                                          Width="92" Height="34"
                                          Margin="0 0 0 8"
                                          ToolTip="Отключить выбранную дорожку"
                                          Checked="MuteToggle_Changed"
                                          Unchecked="MuteToggle_Changed"/>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Параметры"
                                   Style="{StaticResource GroupLabel}"/>
                        <WrapPanel>
                            <TextBlock Text="Скорость"
                                       Style="{StaticResource FieldLabel}"/>

                            <Button Content="-"
                                    Style="{StaticResource TabActionButton}"
                                    Width="34"
                                    Margin="0 0 4 8"
                                    ToolTip="Уменьшить скорость на 5%"
                                    Click="SpeedDown_Click"/>

                            <TextBox x:Name="SpeedTextBox"
                                     Width="56" Height="34"
                                     Text="100"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Background="#4B3A64"
                                     Foreground="#CDD6F4"
                                     BorderBrush="#4B3A64"
                                     FontWeight="Bold"
                                     Margin="0 0 4 8"
                                     LostFocus="SpeedTextBox_LostFocus"
                                     KeyDown="SpeedTextBox_KeyDown"/>

                            <Button Content="+"
                                    Style="{StaticResource TabActionButton}"
                                    Width="34"
                                    Margin="0 0 4 8"
                                    ToolTip="Увеличить скорость на 5%"
                                    Click="SpeedUp_Click"/>

                            <TextBlock Text="%"
                                       VerticalAlignment="Center"
                                       Foreground="#9B8BB8"
                                       FontSize="12"
                                       Margin="0 0 16 8"/>

                            <CheckBox x:Name="AutoScrollCheckBox"
                                      Content="Следить за курсором"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Margin="0 0 0 8"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Background="#1A1525"
                        BorderBrush="#352847"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10 7"
                        Margin="0 4 0 0">
                    <TextBlock x:Name="StatusText"
                               Text="Откройте файл Guitar Pro или MusicXML"
                               Style="{StaticResource StatusTextStyle}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#F7F5FA"
                CornerRadius="6"
                Padding="8">
            <ScrollViewer x:Name="TabScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          PanningMode="Both"
                          SizeChanged="TabScrollViewer_SizeChanged"
                          PreviewMouseWheel="TabScrollViewer_PreviewMouseWheel">
                <wpf:AlphaTab x:Name="AlphaTab"
                              Tracks="{Binding TracksToDisplay}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

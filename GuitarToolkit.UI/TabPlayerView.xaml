<UserControl x:Class="GuitarToolkit.UI.TabPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:AlphaTab.Wpf;assembly=AlphaTab.Windows"
             Background="#1A1525">

    <UserControl.Resources>
        <Style x:Key="TabModeToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="#4B3A64"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#4B3A64"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#5B4676"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5B4676"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#CBA6F7"/>
                                <Setter Property="Foreground" Value="#1A1525"/>
                                <Setter Property="BorderBrush" Value="#CBA6F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0 0 0 12">
            <WrapPanel Margin="0 0 0 8"
                       VerticalAlignment="Center">
                <Button Content="Открыть"
                        Width="110" Height="34"
                        Margin="0 0 10 6"
                        FontWeight="Bold"
                        Background="#CBA6F7"
                        Foreground="#1A1525"
                        Click="OpenFile_Click"/>

                <ComboBox x:Name="RecentFilesCombo"
                          Width="220" Height="34"
                          Margin="0 0 10 6"
                          ToolTip="Последние табулатуры"
                          ItemsSource="{Binding RecentTabFiles}"
                          SelectionChanged="RecentFilesCombo_SelectionChanged"/>

                <ComboBox x:Name="TrackCombo"
                          Width="260" Height="34"
                          Margin="0 0 10 6"
                          SelectionChanged="TrackCombo_SelectionChanged"/>

                <ToggleButton x:Name="PlayPauseToggle"
                              Content="▶ Играть"
                              Style="{StaticResource TabModeToggleStyle}"
                              Width="104" Height="34"
                              Margin="0 0 6 6"
                              ToolTip="Играть / пауза"
                              Checked="PlayPauseToggle_Changed"
                              Unchecked="PlayPauseToggle_Changed"/>

                <Button Content="Стоп"
                        Width="76" Height="34"
                        Margin="0 0 10 6"
                        ToolTip="Стоп"
                        Click="Stop_Click"/>

                <ToggleButton x:Name="SoloToggle"
                              Content="Соло"
                              Style="{StaticResource TabModeToggleStyle}"
                              Width="70" Height="34"
                              Margin="0 0 6 6"
                              ToolTip="Играть только выбранную дорожку"
                              Checked="SoloToggle_Changed"
                              Unchecked="SoloToggle_Changed"/>

                <ToggleButton x:Name="MuteToggle"
                              Content="Не играть"
                              Style="{StaticResource TabModeToggleStyle}"
                              Width="92" Height="34"
                              Margin="0 0 0 6"
                              ToolTip="Отключить выбранную дорожку"
                              Checked="MuteToggle_Changed"
                              Unchecked="MuteToggle_Changed"/>
            </WrapPanel>

            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Громкость"
                           VerticalAlignment="Center"
                           Foreground="#7C6F96"
                           FontSize="12"
                           Margin="0 0 6 0"/>

                <Slider x:Name="VolumeSlider"
                        Width="120"
                        Minimum="0"
                        Maximum="100"
                        Value="35"
                        TickFrequency="5"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"/>

                <TextBlock x:Name="VolumeLabel"
                           Text="35%"
                           Width="42"
                           VerticalAlignment="Center"
                           Foreground="#CDD6F4"
                           FontSize="12"
                           Margin="6 0 16 0"/>

                <TextBlock Text="Скорость"
                           VerticalAlignment="Center"
                           Foreground="#7C6F96"
                           FontSize="12"
                           Margin="0 0 6 0"/>

                <Button Content="-"
                        Width="34" Height="34"
                        Margin="0 0 4 0"
                        ToolTip="Уменьшить скорость на 5%"
                        Click="SpeedDown_Click"/>

                <TextBox x:Name="SpeedTextBox"
                         Width="56" Height="34"
                         Text="100"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Background="#4B3A64"
                         Foreground="#CDD6F4"
                         BorderBrush="#4B3A64"
                         FontWeight="Bold"
                         LostFocus="SpeedTextBox_LostFocus"
                         KeyDown="SpeedTextBox_KeyDown"/>

                <Button Content="+"
                        Width="34" Height="34"
                        Margin="4 0 0 0"
                        ToolTip="Увеличить скорость на 5%"
                        Click="SpeedUp_Click"/>

                <TextBlock Text="%"
                           VerticalAlignment="Center"
                           Foreground="#7C6F96"
                           FontSize="12"
                           Margin="4 0 12 0"/>

                <CheckBox x:Name="AutoScrollCheckBox"
                          Content="Следить"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Foreground="#CDD6F4"
                          FontWeight="Bold"
                          Margin="0 0 14 0"/>

                <TextBlock Text="Синхр."
                           VerticalAlignment="Center"
                           Foreground="#7C6F96"
                           FontSize="12"
                           Margin="0 0 6 0"/>

                <Slider x:Name="SyncOffsetSlider"
                        Width="110"
                        Minimum="-200"
                        Maximum="200"
                        Value="0"
                        TickFrequency="10"
                        VerticalAlignment="Center"
                        ValueChanged="SyncOffsetSlider_ValueChanged"/>

                <TextBlock x:Name="SyncOffsetLabel"
                           Text="0 мс"
                           Width="52"
                           VerticalAlignment="Center"
                           Foreground="#CDD6F4"
                           FontSize="12"
                           Margin="6 0 12 0"/>

                <TextBlock x:Name="StatusText"
                           Text="Откройте файл Guitar Pro или MusicXML"
                           VerticalAlignment="Center"
                           Foreground="#7C6F96"
                           FontSize="13"
                           Margin="12 0 0 0"/>
            </WrapPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#F7F5FA"
                CornerRadius="6"
                Padding="8">
            <ScrollViewer x:Name="TabScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          PanningMode="Both"
                          SizeChanged="TabScrollViewer_SizeChanged"
                          PreviewMouseWheel="TabScrollViewer_PreviewMouseWheel">
                <wpf:AlphaTab x:Name="AlphaTab"
                              Tracks="{Binding TracksToDisplay}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

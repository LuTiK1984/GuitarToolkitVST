<UserControl x:Class="GuitarToolkit.UI.TabPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:AlphaTab.Wpf;assembly=AlphaTab.Windows"
             Background="#1A1525">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0 0 0 12">
            <Button Content="Открыть"
                    Width="110" Height="34"
                    Margin="0 0 10 0"
                    FontWeight="Bold"
                    Background="#CBA6F7"
                    Foreground="#1A1525"
                    Click="OpenFile_Click"/>

            <ComboBox x:Name="TrackCombo"
                      Width="260" Height="34"
                      Margin="0 0 10 0"
                      DisplayMemberPath="Name"
                      SelectionChanged="TrackCombo_SelectionChanged"/>

            <TextBlock x:Name="StatusText"
                       Text="Откройте файл Guitar Pro или MusicXML"
                       VerticalAlignment="Center"
                       Foreground="#7C6F96"
                       FontSize="13"/>
        </DockPanel>

        <Border Grid.Row="1"
                Background="#241B33"
                CornerRadius="6"
                Padding="12"
                Margin="0 0 0 12">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#CDD6F4"
                       FontSize="13"
                       Text="Первый прототип вкладки табулатур: загрузка файлов Guitar Pro / MusicXML, выбор дорожки и отображение нотной записи с табулатурой через alphaTab."/>
        </Border>

        <Border Grid.Row="2"
                Background="#F7F5FA"
                CornerRadius="6"
                Padding="8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <wpf:AlphaTab x:Name="AlphaTab"
                              Tracks="{Binding TracksToDisplay}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

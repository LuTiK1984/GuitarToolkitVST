<UserControl x:Class="GuitarToolkit.UI.ToolkitHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GuitarToolkit.UI"
             Background="#1A1525"
             MinWidth="750" MinHeight="500">

    <UserControl.Resources>

        <!-- Вкладки -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#2D2240"
                                Padding="14 10" Margin="2" CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBA6F7"/>
                                <Setter Property="Foreground" Value="#1A1525"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A3860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>

        <!-- Кнопки -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A3860"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A4870"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBA6F7"/>
                                <Setter Property="Foreground" Value="#1A1525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox toggle -->
        <ControlTemplate x:Key="ComboToggle" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="#4A3860" CornerRadius="6"
                    Padding="10 6" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="▾" FontSize="14"
                               Foreground="#CDD6F4" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#5A4870"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="12 6 28 6"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2D2240" CornerRadius="6"
                                        BorderBrush="#4A3860" BorderThickness="1"
                                        Padding="4" Margin="0 4 0 0">
                                    <ScrollViewer MaxHeight="300">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="10 7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBA6F7"/>
                                <Setter Property="Foreground" Value="#1A1525"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A3860"/>
                                <Setter Property="Foreground" Value="#CBA6F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Слайдеры -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#CBA6F7"/>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>

        <!-- ScrollViewer — скрываем полосу, оставляем скролл -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

    </UserControl.Resources>

    <TabControl Background="#1A1525" BorderThickness="0" TabStripPlacement="Left">

        <TabItem Header="🎸 Тюнер">
            <ScrollViewer>
                <local:TunerView x:Name="TunerTab"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="🥁 Метроном">
            <local:MetronomeView x:Name="MetronomeTab"/>
        </TabItem>

        <TabItem Header="🎵 Аккорды">
            <ScrollViewer>
                <local:ChordView x:Name="ChordTab"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="🎼 Гаммы">
            <local:FretboardView x:Name="FretboardTab"/>
        </TabItem>

        <TabItem Header="🎧 Интервалы">
            <ScrollViewer>
                <local:IntervalTrainerView x:Name="IntervalTab"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="🎶 Прогрессии">
            <ScrollViewer>
                <local:ProgressionView x:Name="ProgressionTab"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="⭕ Круг квинт">
            <local:CircleOfFifthsView x:Name="CircleTab"/>
        </TabItem>

    </TabControl>
</UserControl>

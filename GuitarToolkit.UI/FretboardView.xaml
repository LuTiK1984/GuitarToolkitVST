<UserControl x:Class="GuitarToolkit.UI.FretboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тоника + гамма + кнопки -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <TextBlock Text="Тоника:" FontSize="14" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="0 0 12 0"/>
                <ItemsControl x:Name="RootSelector">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Гамма:" FontSize="14" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="0 0 12 0"/>
                <ComboBox x:Name="ScaleBox" Width="280" Height="30"
                          SelectionChanged="ScaleBox_SelectionChanged"
                          ToolTip="Выберите гамму или лад"/>

                <Button x:Name="ModeButton" Content="Ноты"
                        Width="100" Height="30" FontSize="13"
                        Background="#4A3860" Foreground="#CDD6F4"
                        BorderThickness="0" Cursor="Hand"
                        Margin="12 0 0 0" Click="ModeButton_Click"
                        ToolTip="Переключить отображение: ноты / ступени"/>

                <Button x:Name="PlayScaleButton" Content="🔊 Играть"
                        Width="100" Height="30" FontSize="13"
                        Background="#CBA6F7" Foreground="#1A1525"
                        BorderThickness="0" Cursor="Hand"
                        Margin="8 0 0 0" Click="PlayScale_Click"
                        ToolTip="Воспроизвести выбранную гамму"/>
            </StackPanel>
        </StackPanel>

        <!-- Инфо -->
        <TextBlock Grid.Row="1" x:Name="InfoLabel"
                   FontSize="13" Foreground="#7C6F96"
                   Margin="0 0 0 8"/>

        <!-- Гриф -->
        <Border Grid.Row="2" Background="#251D38" CornerRadius="8" Padding="12">
            <Canvas x:Name="FretboardCanvas"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    SizeChanged="Canvas_SizeChanged"/>
        </Border>
    </Grid>
</UserControl>

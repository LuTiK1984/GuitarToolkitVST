<UserControl x:Class="GuitarToolkit.UI.TunerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="20 12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Строй и эталон -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0 4 0 0">

            <StackPanel Margin="0 0 32 0">
                <TextBlock Text="Строй" Foreground="#7C6F96" FontSize="12"
                           HorizontalAlignment="Center" Margin="0 0 0 4"/>
                <ComboBox x:Name="TuningBox" Width="220" Height="32"
                          SelectionChanged="TuningBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Эталон (Hz)" Foreground="#7C6F96" FontSize="12"
                           HorizontalAlignment="Center" Margin="0 0 0 4"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="−" Width="34" Height="34"
                            Click="RefDown_Click" FontSize="16"/>
                    <TextBlock x:Name="RefLabel" Text="440"
                               FontSize="22" FontWeight="Bold" Foreground="#CBA6F7"
                               VerticalAlignment="Center" Margin="12 0"
                               MinWidth="44" TextAlignment="Center"/>
                    <Button Content="+" Width="34" Height="34"
                            Click="RefUp_Click" FontSize="16"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Нота и стрелка -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock x:Name="NoteLabel" Text="—"
                       FontSize="88" FontWeight="Bold" Foreground="#CDD6F4"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="FreqLabel" Text="— Hz"
                       FontSize="16" Foreground="#7C6F96"
                       HorizontalAlignment="Center" Margin="0 -6 0 16"/>

            <!-- Шкала центов -->
            <Grid Width="340" Height="65" Margin="0 0 0 6">
                <Rectangle Height="4" VerticalAlignment="Center"
                           Fill="#2D2240" RadiusX="2" RadiusY="2"/>
                <Rectangle Width="3" Height="20" Fill="#A6E3A1"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Text="-50" Foreground="#7C6F96" FontSize="11"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <TextBlock Text="0" Foreground="#7C6F96" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <TextBlock Text="+50" Foreground="#7C6F96" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                <Canvas Width="340" Height="55" VerticalAlignment="Center">
                    <Polygon x:Name="NeedleArrow"
                             Points="0,-18 6,10 -6,10" Fill="#CBA6F7">
                        <Polygon.RenderTransform>
                            <TranslateTransform x:Name="NeedleTranslate" X="170" Y="28"/>
                        </Polygon.RenderTransform>
                    </Polygon>
                </Canvas>
            </Grid>

            <TextBlock x:Name="CentsLabel" Text="0 центов"
                       FontSize="15" Foreground="#7C6F96"
                       HorizontalAlignment="Center"/>

            <Border x:Name="InTuneIndicator" Background="#2D2240"
                    CornerRadius="8" Padding="24 8" Margin="0 10 0 0"
                    HorizontalAlignment="Center">
                <TextBlock x:Name="InTuneLabel" Text="Ожидание сигнала..."
                           FontSize="15" FontWeight="Bold" Foreground="#7C6F96"
                           HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- Струны -->
        <StackPanel Grid.Row="2" Margin="0 0 0 8">
            <TextBlock Text="Струны" Foreground="#7C6F96" FontSize="12"
                       HorizontalAlignment="Center" Margin="0 8 0 6"/>
            <ItemsControl x:Name="StringsPanel" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <!-- Уровень + усиление -->
        <StackPanel Grid.Row="3" Margin="0 0 0 8">
            <TextBlock Text="Уровень сигнала" Foreground="#7C6F96" FontSize="12"
                       HorizontalAlignment="Center" Margin="0 0 0 4"/>
            <Grid Width="340" Height="14" HorizontalAlignment="Center" Margin="0 0 0 8">
                <Rectangle Fill="#1e3a2a" RadiusX="7" RadiusY="7"/>
                <Rectangle x:Name="VolumeBar" Fill="#A6E3A1"
                           HorizontalAlignment="Left" Width="0" RadiusX="7" RadiusY="7"/>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Усиление:" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="0 0 8 0" FontSize="13"/>
                <Slider x:Name="GainSlider" Minimum="0" Maximum="40" Value="20"
                        Width="180" VerticalAlignment="Center"
                        ValueChanged="GainSlider_ValueChanged"/>
                <TextBlock x:Name="GainLabel" Text="+20 dB"
                           Foreground="#CDD6F4" FontSize="13"
                           VerticalAlignment="Center" Margin="8 0 0 0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

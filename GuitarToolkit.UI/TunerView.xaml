<UserControl x:Class="GuitarToolkit.UI.TunerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#241B33"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#352847"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#4B3A64"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#5B4676"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#F38BA8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9B8BB8"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#1A1525"/>

        <Style x:Key="Panel" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionPanel" TargetType="{x:Type Border}" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="{DynamicResource DarkBrush}"/>
            <Setter Property="Padding" Value="10 8"/>
        </Style>

        <Style x:Key="GroupLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TunerButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="8 0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="TunerComboToggle" TargetType="{x:Type ToggleButton}">
            <Border x:Name="Chrome"
                    Background="{DynamicResource ControlBrush}"
                    BorderBrush="{DynamicResource ControlBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="8 0 0 0"/>
                    <TextBlock Grid.Column="1"
                               Text="v"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ControlHoverBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Template="{StaticResource TunerComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="9 0 28 0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="3"
                                        Margin="0 4 0 0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="9 6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4"
                                    Background="{DynamicResource ControlBrush}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Background="{DynamicResource AccentBrush}"
                                                  BorderThickness="0"
                                                  Height="4"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Height="4"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12"
                                           Height="20"
                                           Background="{DynamicResource TextBrush}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="42*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="58*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="&#x423;&#x441;&#x442;&#x440;&#x43E;&#x439;&#x441;&#x442;&#x432;&#x43E; &#x432;&#x432;&#x43E;&#x434;&#x430;"
                               Style="{StaticResource GroupLabel}"/>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="InputDeviceBox"
                                  Grid.Column="0"
                                  SelectionChanged="InputDeviceBox_SelectionChanged"/>
                        <Border Grid.Column="2"
                                Background="{DynamicResource DarkBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10 4"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="InputStatusLabel"
                                       Text="&#x412;&#x445;&#x43E;&#x434; &#x43D;&#x435; &#x432;&#x44B;&#x431;&#x440;&#x430;&#x43D;"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource SectionPanel}">
                    <Grid VerticalAlignment="Center"
                          Margin="0 14 0 14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="NoteLabel"
                                       Text="—"
                                       FontSize="86"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5"/>
                            <TextBlock x:Name="FreqLabel"
                                       Text="— Hz"
                                       Style="{StaticResource MutedText}"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       Margin="0 -8 0 0"/>
                        </StackPanel>

                        <Grid Grid.Row="2"
                              Width="340"
                              Height="78"
                              ClipToBounds="True"
                              HorizontalAlignment="Center">
                            <Border Height="6"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PanelBorderBrush}"
                                    CornerRadius="3"/>
                            <Border Width="4"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource GoodBrush}"
                                    CornerRadius="2"/>
                            <Grid Margin="0 0 0 2"
                                  VerticalAlignment="Bottom">
                                <TextBlock Text="-50"
                                           Style="{StaticResource MutedText}"
                                           Width="38"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Left"
                                           Margin="4 0 0 0"/>
                                <TextBlock Text="0"
                                           Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="+50"
                                           Style="{StaticResource MutedText}"
                                           Width="38"
                                           TextAlignment="Right"
                                           HorizontalAlignment="Right"
                                           Margin="0 0 4 0"/>
                            </Grid>
                            <Canvas x:Name="NeedleCanvas"
                                    Width="340"
                                    Height="66"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Polygon x:Name="NeedleArrow"
                                         Points="0,-20 7,11 -7,11"
                                         Fill="{DynamicResource AccentBrush}">
                                    <Polygon.RenderTransform>
                                        <TranslateTransform x:Name="NeedleTranslate" X="170" Y="33"/>
                                    </Polygon.RenderTransform>
                                </Polygon>
                            </Canvas>
                        </Grid>

                        <TextBlock x:Name="CentsLabel"
                                   Grid.Row="4"
                                   Text="0 &#x446;&#x435;&#x43D;&#x442;&#x43E;&#x432;"
                                   Style="{StaticResource MutedText}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>

                        <Border x:Name="InTuneIndicator"
                                Grid.Row="6"
                                Background="{DynamicResource ControlBrush}"
                                CornerRadius="6"
                                Padding="12 6"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="InTuneLabel"
                                       Text="&#x41E;&#x436;&#x438;&#x434;&#x430;&#x43D;&#x438;&#x435; &#x441;&#x438;&#x433;&#x43D;&#x430;&#x43B;&#x430;"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="&#x421;&#x442;&#x440;&#x443;&#x43D;&#x44B;"
                               Style="{StaticResource GroupLabel}"/>
                    <ItemsControl x:Name="StringsPanel"
                                  Grid.Row="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x421;&#x442;&#x440;&#x43E;&#x439;"
                                       Style="{StaticResource GroupLabel}"/>
                            <ComboBox x:Name="TuningBox"
                                      MinWidth="260"
                                      SelectionChanged="TuningBox_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="&#x42D;&#x442;&#x430;&#x43B;&#x43E;&#x43D; A4"
                                       Style="{StaticResource GroupLabel}"
                                       TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="-"
                                        Style="{StaticResource TunerButton}"
                                        Width="30"
                                        Click="RefDown_Click"/>
                                <TextBlock x:Name="RefLabel"
                                           Text="440"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Width="46"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button Content="+"
                                        Style="{StaticResource TunerButton}"
                                        Width="30"
                                        Click="RefUp_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#x421;&#x438;&#x433;&#x43D;&#x430;&#x43B;"
                               Style="{StaticResource GroupLabel}"/>

                    <Grid Grid.Row="2"
                          Height="12">
                        <Rectangle Fill="{DynamicResource ControlBrush}"
                                   RadiusX="7"
                                   RadiusY="7"/>
                        <Rectangle x:Name="VolumeBar"
                                   Fill="{DynamicResource GoodBrush}"
                                   Opacity="0.7"
                                   HorizontalAlignment="Left"
                                   Width="0"
                                   RadiusX="7"
                                   RadiusY="7"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x423;&#x441;&#x438;&#x43B;&#x435;&#x43D;&#x438;&#x435;"
                                   Grid.Column="0"
                                   Style="{StaticResource GroupLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0"/>
                        <Slider x:Name="GainSlider"
                                Grid.Column="2"
                                Minimum="0"
                                Maximum="40"
                                Value="20"
                                ValueChanged="GainSlider_ValueChanged"/>
                        <TextBlock x:Name="GainLabel"
                                   Grid.Column="4"
                                   Text="+20 dB"
                                   Style="{StaticResource MutedText}"
                                   Width="54"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="&#x414;&#x430;&#x43B;&#x44C;&#x448;&#x435; &#x441;&#x44E;&#x434;&#x430; &#x43F;&#x440;&#x43E;&#x441;&#x44F;&#x442;&#x441;&#x44F;"
                               Style="{StaticResource GroupLabel}"/>
                    <WrapPanel Grid.Row="2">
                        <Border Style="{StaticResource SectionPanel}"
                                Margin="0 0 6 6"
                                Padding="8 6">
                            <TextBlock Text="&#x441;&#x442;&#x440;&#x43E;&#x431;"
                                       Style="{StaticResource MutedText}"/>
                        </Border>
                        <Border Style="{StaticResource SectionPanel}"
                                Margin="0 0 6 6"
                                Padding="8 6">
                            <TextBlock Text="&#x440;&#x435;&#x436;&#x438;&#x43C; &#x441;&#x442;&#x440;&#x443;&#x43D;"
                                       Style="{StaticResource MutedText}"/>
                        </Border>
                        <Border Style="{StaticResource SectionPanel}"
                                Margin="0 0 6 6"
                                Padding="8 6">
                            <TextBlock Text="&#x441;&#x442;&#x430;&#x431;&#x438;&#x43B;&#x44C;&#x43D;&#x43E;&#x441;&#x442;&#x44C;"
                                       Style="{StaticResource MutedText}"/>
                        </Border>
                        <Border Style="{StaticResource SectionPanel}"
                                Margin="0 0 6 6"
                                Padding="8 6">
                            <TextBlock Text="&#x448;&#x443;&#x43C;&#x43E;&#x432;&#x43E;&#x439; &#x43F;&#x43E;&#x440;&#x43E;&#x433;"
                                       Style="{StaticResource MutedText}"/>
                        </Border>
                    </WrapPanel>
                    <TextBlock Grid.Row="4"
                               Text="&#x424;&#x443;&#x43D;&#x43A;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B; &#x437;&#x430;&#x444;&#x438;&#x43A;&#x441;&#x438;&#x440;&#x43E;&#x432;&#x430;&#x43D; &#x432; roadmap, &#x434;&#x43E;&#x431;&#x430;&#x432;&#x438;&#x43C; &#x43F;&#x43E;&#x441;&#x43B;&#x435; &#x43F;&#x440;&#x43E;&#x445;&#x43E;&#x434;&#x430; &#x43F;&#x43E; GUI."
                               Style="{StaticResource MutedText}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

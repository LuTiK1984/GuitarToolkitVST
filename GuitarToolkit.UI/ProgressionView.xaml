<UserControl x:Class="GuitarToolkit.UI.ProgressionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тональность + мажор/минор -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <TextBlock Text="Тональность:" FontSize="14" Foreground="#7C6F96"
                           VerticalAlignment="Center" Margin="0 0 12 0"/>
                <ItemsControl x:Name="KeySelector">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Button x:Name="ModeButton" Content="Мажор" Width="90" Height="30"
                        FontSize="13" FontWeight="Bold" Margin="16 0 0 0"
                        Background="#CBA6F7" Foreground="#1A1525"
                        BorderThickness="0" Cursor="Hand"
                        Click="Mode_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Ступени -->
        <StackPanel Grid.Row="1" Margin="0 0 0 12">
            <TextBlock Text="Ступени (нажми чтобы добавить):"
                       FontSize="13" Foreground="#7C6F96" Margin="0 0 0 8"/>
            <ItemsControl x:Name="DegreeButtons">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <!-- Пресеты -->
        <StackPanel Grid.Row="2" Margin="0 0 0 12">
            <TextBlock Text="Пресеты:" FontSize="13" Foreground="#7C6F96" Margin="0 0 0 8"/>
            <ItemsControl x:Name="PresetButtons">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <!-- Текущая прогрессия -->
        <Border Grid.Row="3" Background="#251D38" CornerRadius="8"
                Padding="16 12" Margin="0 0 0 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Прогрессия:" FontSize="13" Foreground="#7C6F96"
                               Margin="0 0 0 6"/>
                    <ItemsControl x:Name="ProgressionDisplay">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button x:Name="PlayButton" Content="▶ Играть"
                            Height="40" Width="120"
                            FontSize="14" FontWeight="Bold"
                            Foreground="#1A1525" Background="#CBA6F7"
                            BorderThickness="0" Cursor="Hand"
                            Click="Play_Click" Margin="0 0 0 4"/>
                    <Button x:Name="StopButton" Content="⏹ Стоп"
                            Height="32" Width="120" FontSize="12"
                            Foreground="#1A1525" Background="#F38BA8"
                            BorderThickness="0" Cursor="Hand"
                            Click="Stop_Click" Margin="0 0 0 4"
                            Visibility="Collapsed"/>
                    <Button Content="Очистить" Height="28" Width="120"
                            FontSize="12" Foreground="#CDD6F4" Background="#4A3860"
                            BorderThickness="0" Cursor="Hand"
                            Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Сохранение пресета -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 0 0 12">
            <TextBox x:Name="PresetNameBox" Width="220" Height="30"
                     Background="#2D2240" Foreground="#CDD6F4" BorderThickness="0"
                     FontSize="13" Padding="8 4"
                     VerticalContentAlignment="Center"
                     Text="" Tag="Название пресета..."
                     GotFocus="PresetNameBox_GotFocus"
                     LostFocus="PresetNameBox_LostFocus"/>
            <Button Content="💾 Сохранить пресет" Height="30"
                    FontSize="12" Foreground="#CDD6F4" Background="#4A3860"
                    BorderThickness="0" Cursor="Hand"
                    Margin="8 0 0 0" Padding="12 0"
                    Click="SavePreset_Click"/>
        </StackPanel>

        <!-- BPM + Loop -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Top">
            <TextBlock Text="Темп:" FontSize="13" Foreground="#7C6F96"
                       VerticalAlignment="Center" Margin="0 0 8 0"/>
            <Slider x:Name="BpmSlider" Minimum="60" Maximum="200" Value="120"
                    Width="200" VerticalAlignment="Center"
                    ValueChanged="Bpm_Changed"/>
            <TextBlock x:Name="BpmLabel" Text="120 BPM" FontSize="13"
                       Foreground="#CDD6F4" VerticalAlignment="Center" Margin="8 0 24 0"/>
            <CheckBox x:Name="LoopCheck" Content="Зацикливать"
                      Foreground="#CDD6F4" FontSize="13"
                      VerticalAlignment="Center" IsChecked="True"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="GuitarToolkit.UI.IntervalTrainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1525">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и статистика -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 16">
            <TextBlock Text="Тренажёр интервалов" FontSize="22" FontWeight="Bold"
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatsLabel" Text="  |  0/0 (0%)"
                       FontSize="14" Foreground="#7C6F96"
                       VerticalAlignment="Center" Margin="16 0 0 0"/>
            <Button Content="Сброс" Width="70" Height="28" FontSize="12"
                    Margin="16 0 0 0" Click="Reset_Click"
                    Background="#4A3860" Foreground="#CDD6F4" BorderThickness="0"/>
        </StackPanel>

        <!-- Настройки сложности -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 20">
            <TextBlock Text="Диапазон:" Foreground="#7C6F96" FontSize="13"
                       VerticalAlignment="Center" Margin="0 0 8 0"/>
            <ComboBox x:Name="DifficultyBox" Width="220" Height="30"
                      SelectionChanged="Difficulty_Changed">
                <ComboBoxItem Content="До квинты (легко)" Tag="7"/>
                <ComboBoxItem Content="До октавы (средне)" Tag="12" IsSelected="True"/>
                <ComboBoxItem Content="Все + унисон" Tag="13"/>
            </ComboBox>
        </StackPanel>

        <!-- Основная область -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Результат последнего ответа -->
            <Border x:Name="ResultBorder" Background="Transparent"
                    CornerRadius="8" Padding="24 12" Margin="0 0 0 20"
                    HorizontalAlignment="Center" MinWidth="300">
                <TextBlock x:Name="ResultLabel" Text="Нажми «Играть» чтобы начать"
                           FontSize="18" Foreground="#7C6F96"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Кнопка воспроизведения -->
            <Button x:Name="PlayButton" Content="🔊  Играть интервал"
                    Height="52" Width="280" FontSize="16" FontWeight="Bold"
                    Foreground="#1A1525" Background="#CBA6F7"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0 0 0 24" Click="Play_Click"/>

            <!-- Кнопки ответов — сетка интервалов -->
            <TextBlock Text="Какой интервал?" FontSize="14" Foreground="#7C6F96"
                       HorizontalAlignment="Center" Margin="0 0 0 12"/>

            <ItemsControl x:Name="AnswerButtons" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel MaxWidth="600"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Кнопка «Повторить» -->
            <Button x:Name="RepeatButton" Content="🔁 Повторить" IsEnabled="False"
                    Height="36" Width="180" FontSize="13"
                    Foreground="#CDD6F4" Background="#4A3860"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0 16 0 0" Click="Repeat_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
